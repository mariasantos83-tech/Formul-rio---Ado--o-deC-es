<h2>Formulário de Adoção</h2>
<form id="formAdocao">
    <label for="nome">Nome:</label>
    <input type="text" id="nome" name="nome" placeholder="digite seu nome" required>
    <br>
    <label for="email">Email:</label>
    <input type="email" id="email" name="email" placeholder="digite seu email" required>
    <br>
    <label for="telefone">Telefone:</label>
    <input type="tel" id="telefone" name="telefone" placeholder="digite seu telefone" required>
    <br>
    <label for="CPF">CPF:</label>
    <input type="text" id="CPF" name="CPF" placeholder="000.000.000-00" required>
    <br>
    <label for="idade">Idade:</label>
    <input type="number" id="idade" name="idade" placeholder="digite sua idade" required>
    <br>
    <label for="cidade">Cidade:</label>
    <input type="text" id="cidade" name="cidade" placeholder="digite sua cidade" required>
    <br>
    <label for="moradia">Moradia:</label>
    <select name="moradia" id="moradia" required>
        <option value="">Selecione</option>
        <option value="Casa">Casa</option>
        <option value="apartamento">Apartamento</option>
        <option value="condominio">Condomínio</option>
    </select>
    <br>
    <label>Possui Quintal?</label>
    <input type="radio" name="quintal" value="Sim" required>Sim
    <input type="radio" name="quintal" value="Nao">Não
    <br>
    <label for="animal">Já teve animal de estimação antes?</label>
    <select name="animal" id="animal" required>
        <option value="">Selecione</option>
        <option value="Sim">Sim</option>
        <option value="Nao">Não</option>
    </select>
    <br>
    <label for="horas_sozinho">Quantas horas o animal ficará sozinho por dia?</label>
    <select name="horas_sozinho" id="horas_sozinho" required>
        <option value="">Selecione</option>
        <option value="1">1 hora</option>
        <option value="2">2 horas</option>
        <option value="3">3 horas</option>
        <option value="4+">4 ou mais horas</option>
    </select>
    <br>
    <button type="submit">Enviar Adoção</button>
</form>
